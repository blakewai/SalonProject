<Page x:Class="SalonProject.Pages.PagesAllUser.Profile"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SalonProject.Pages.PagesAllUser"
      mc:Ignorable="d" 
      d:DesignHeight="1080" d:DesignWidth="1920"
      Title="Profile">

    <Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="39*"/>
                <RowDefinition Height="124*"/>
            </Grid.RowDefinitions>

            <Button Width="200" Height="200" HorizontalAlignment="Left">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border BorderThickness="1" BorderBrush="Black" Cursor="Hand" Width="200" Height="200">
                            <Image Name="ProfilePhotoIMG" Source="/Images/iconsadmin.png" Width="200" Height="200"></Image>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <StackPanel Grid.Row="1">
                <Label Content="Фамилия" FontSize="30"/>
                <TextBox IsEnabled="False" Name="PatronymicTB" Height="50" FontSize="36" BorderThickness="1" BorderBrush="Black" Background="{x:Null}"/>
                <Label Content="Имя" FontSize="30"/>
                <TextBox IsEnabled="False" Name="NameTB" Height="50" FontSize="36" BorderThickness="1" BorderBrush="Black" Background="{x:Null}"/>
                <Label Content="Отчество" FontSize="30"/>
                <TextBox IsEnabled="False" Name="LastNameTB" Height="50" FontSize="36" BorderThickness="1" BorderBrush="Black" Background="{x:Null}"/>
                <Label Content="День рождения" FontSize="30"/>
                <DatePicker IsEnabled="False" Name="BirthDayTB" Height="50" FontSize="36" BorderThickness="1" BorderBrush="Black" Background="{x:Null}"/>
                <Label Content="Номер" FontSize="30"/>
                <TextBox IsEnabled="False" Name="NumberTB" Height="50" FontSize="36" BorderThickness="1" BorderBrush="Black" Background="{x:Null}"/>
                <Label Content="Почта" FontSize="30"/>
                <TextBox IsEnabled="False" Name="EmailTB" Height="50" FontSize="36" BorderThickness="1" BorderBrush="Black" Background="{x:Null}"/>
            </StackPanel>
            <Button Grid.Column="1" 
                    Width="400" 
                    Height="100" 
                    HorizontalAlignment="Right"
                    BorderBrush="Black"
                    BorderThickness="1"
                    Background="#FFEBEB"
                    Content="Добавить" 
                    FontSize="40" Click="Add_Click"/>
        </Grid>
        <Frame Name="ProfileEdit"/>
    </Grid>
</Page>
