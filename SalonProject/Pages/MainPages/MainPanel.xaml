<Page x:Class="SalonProject.Pages.MainPages.MainPanel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:SalonProject.Pages.MainPages"
      mc:Ignorable="d" 
      d:DesignHeight="1080" d:DesignWidth="1920"
      Title="MainPanel">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="2"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Image Source="/Images/iconsshoppingbag.png" 
           HorizontalAlignment="Left" 
           Width="70" Height="70"/>

        <Grid Grid.Row="1" Background="Black"/>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="2"/>
                <ColumnDefinition Width="1520"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="1"  Background="Black"/>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Column="0" Grid.Row="0" 
                    Grid.RowSpan="17" Background="MistyRose">

                    <StackPanel>

                        <TextBlock Text="Панель Кого-то!" Name="PanelUsers"
                           FontSize="30" HorizontalAlignment="Center" 
                           VerticalAlignment="Center" />
                        <Button x:Name="BtnManager" Margin="0,30" Click="BtnManager_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Cursor="Hand">
                                        <Grid Background="LightPink">
                                            <TextBlock Text="Менеджеры" FontSize="30"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                            <Image Source="/Images/iconsmanager.png"
                                               HorizontalAlignment="Left" 
                                               Width="60" Height="60"/>
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnEmployee" Click="BtnEmployee_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Cursor="Hand">
                                        <Grid Background="LightPink">
                                            <TextBlock Text="Сотрудники" FontSize="30"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                            <Image Source="/Images/iconsemploy.png"
                                               HorizontalAlignment="Left" 
                                               Width="60" Height="60"/>
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnService" Margin="0,30" Click="BtnService_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Cursor="Hand">
                                        <Grid Background="LightPink">
                                            <TextBlock Text="Услуги" FontSize="30"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                            <Image Source="/Images/iconsservices.png"
                                               HorizontalAlignment="Left" 
                                               Width="60" Height="60"/>
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnInterior" Click="BtnInterior_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Cursor="Hand">
                                        <Grid Background="LightPink">
                                            <TextBlock Text="Салон" FontSize="30"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                            <Image Source="/Images/iconslocation.png"
                                               HorizontalAlignment="Left" 
                                               Width="60" Height="60"/>
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnClient" Margin="0,30" Click="BtnClient_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Cursor="Hand">
                                        <Grid Background="LightPink">
                                            <TextBlock Text="Клиент" FontSize="30"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                            <Image Source="/Images/iconsclient.png"
                                               HorizontalAlignment="Left" 
                                               Width="60" Height="60"/>
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnProfile" Click="BtnProfile_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Cursor="Hand">
                                        <Grid Background="LightPink">
                                            <TextBlock Text="Профиль" FontSize="30"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                            <Image Source="/Images/iconsprofile.png"
                                               HorizontalAlignment="Left" 
                                               Width="60" Height="60"/>
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BtnExitAd" Margin="0,30" Click="BtnExitAd_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Cursor="Hand">
                                        <Grid Background="LightPink">
                                            <TextBlock Text="Выйти" FontSize="30"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                            <Image Source="/Images/iconsexit.png"
                                               HorizontalAlignment="Left" 
                                               Width="60" Height="60"/>
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>

            </Grid>
            <Grid Grid.Column="2">
                <Frame
                   x:Name="FrameUser"
                   NavigationUIVisibility="Hidden" Grid.Column="2">
                    <Frame.JournalOwnership>
                        <JournalOwnership>OwnsJournal</JournalOwnership>
                    </Frame.JournalOwnership>
                </Frame>
            </Grid>
        </Grid>
    </Grid>
</Page>
